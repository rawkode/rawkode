{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "enchiridion",
	"compatibility_date": "2026-06-17",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": "./dist/client",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application",
		"run_worker_first": true
	},
	"observability": { "enabled": true },
	"triggers": {
		"crons": ["*/5 * * * *"]
	},
	"ai": {
		"binding": "AI"
	},
	"vars": {
		"CLOUDFLARE_ACCOUNT_ID": "0aeb879de8e3cdde5fb3d413025222ce",
		"CLOUDFLARE_DISPATCH_NAMESPACE": "enchiridion-mini-apps"
	},
	"secrets": {
		"required": ["CLOUDFLARE_API_TOKEN", "ENCHIRIDION_PASSWORD", "HOST_SIGNING_SECRET"]
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "enchiridion",
			"database_id": "0b7c04ac-8fdc-4941-a9cf-36757c24efa7",
			"migrations_dir": "./migrations"
		}
	],
	"dispatch_namespaces": [
		{
			"binding": "MINI_APP_DISPATCHER",
			"namespace": "enchiridion-mini-apps"
		}
	],
	"worker_loaders": [
		{
			"binding": "LOADER"
		}
	],
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["FlueRegistry", "FlueSecondBrainAgentAgent", "FlueGenerateMiniAppWorkflow"]
		},
		{
			"tag": "v2",
			"new_sqlite_classes": ["FlueRunMiniAppWorkflowWorkflow"]
		},
		{
			"tag": "v3",
			"new_sqlite_classes": ["FlueMiniAppBuilderAgent"]
		}
	]
}
