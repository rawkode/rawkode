{
	"cli_default_open_behavior": "existing_window",
	"tabs": {
		"file_icons": true,
		"git_status": true
	},
	"sticky_scroll": {
		"enabled": true
	},
	"which_key": {
		"enabled": true
	},
	"restore_on_startup": "launchpad",
	"session": {
		"restore_unsaved_buffers": false
	},
	"redact_private_values": true,
	"on_last_window_closed": "quit_app",
	"when_closing_with_no_tabs": "keep_window_open",
	"outline_panel": {
		"dock": "right"
	},
	"agent_servers": {
		"pi-acp": {
			"type": "registry"
		},
		"github-copilot-cli": {
			"type": "registry"
		},
		"claude-acp": {
			"type": "registry"
		},
		"codex-acp": {
			"type": "registry"
		}
	},
	"theme": {
		"mode": "system",
		"dark": "Catppuccin Mocha",
		"light": "Rosé Pine Dawn"
	},
	"icon_theme": {
		"mode": "system",
		"dark": "Zed (Default)",
		"light": "Zed (Default)"
	},
	"buffer_font_family": "Monaspace Neon",
	"buffer_font_size": 16,
	"ui_font_family": "Monaspace Neon",
	"ui_font_size": 14,
	"vim_mode": false,
	"tab_size": 2,
	"soft_wrap": "editor_width",
	"cursor_blink": false,
	"show_whitespaces": "boundary",
	"format_on_save": "on",
	"autosave": "on_focus_change",
	"linked_edits": true,
	"extend_comment_on_newline": true,
	"indent_guides": {
		"enabled": true,
		"coloring": "indent_aware"
	},
	"inlay_hints": {
		"enabled": true,
		"show_type_hints": true,
		"show_parameter_hints": true,
		"show_other_hints": true
	},
	"scrollbar": {
		"show": "auto",
		"cursors": true,
		"git_diff": true,
		"search_results": true,
		"diagnostics": "all"
	},
	"git": {
		"inline_blame": {
			"enabled": true
		}
	},
	"project_panel": {
		"dock": "right",
		"auto_reveal_entries": true
	},
	"agent": {
		"dock": "left"
	},
	"git_panel": {
		"dock": "right"
	},
	"collaboration_panel": {
		"dock": "right"
	},
	"tab_bar": {
		"show_nav_history_buttons": false
	},
	"terminal": {
		"font_family": "Monaspace Neon",
		"font_size": 14,
		"copy_on_select": true
	},
	"telemetry": {
		"metrics": false,
		"diagnostics": false
	},
	"file_scan_exclusions": [
		"**/.git",
		"**/.svn",
		"**/.hg",
		"**/CVS",
		"**/.DS_Store",
		"**/Thumbs.db",
		"**/.classpath",
		"**/.settings",
		"**/node_modules",
		"**/target",
		"**/.direnv",
		"**/result"
	],
	"languages": {
		"Markdown": {
			"soft_wrap": "editor_width"
		},
		"Nix": {
			"formatter": {
				"external": {
					"command": "nixfmt"
				}
			}
		}
	},
	"lsp": {
		"rust-analyzer": {
			"initialization_options": {
				"check": {
					"command": "clippy"
				}
			}
		}
	},
	"auto_install_extensions": {
		"catppuccin": true,
		"nix": true,
		"toml": true,
		"biome": true,
		"sql": true,
		"docker-compose": true,
		"dockerfile": true,
		"editorconfig": true,
		"git-firefly": true,
		"html": true
	},
	"profiles": {
		"screenshare": {
			"settings": {
				"buffer_font_size": 24,
				"ui_font_size": 24
			}
		}
	}
}
