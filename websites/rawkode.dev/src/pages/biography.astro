const academyIconPath =
  'M128,32C74.980712890625,32,32,74.98095703125,32,128C32,181.01904296875,74.980712890625,224,128,224C181.01904296875,224,224,181.01904296875,224,128C224,74.98095703125,181.01904296875,32,128,32ZM102.7740478515625,169.697998046875L82.7235107421875,193.3570556640625L82.7235107421875,85.686767578125C82.7275390625,79.032958984375,88.123046875,73.640869140625,94.7767333984375,73.640380859375L145.5450439453125,73.630859375C143.135986328125,76.696044921875,140.696044921875,79.745849609375,138.31494140625,82.721923828125C135.425048828125,86.334228515625,132.4439697265625,90.0601806640625,129.5379638671875,93.787841796875L102.7740478515625,93.787841796875L102.7740478515625,169.697998046875ZM159.52197265625,175.945068359375C156.343994140625,172.280029296875,152.68798828125,168.1090087890625,148.98095703125,163.8790283203125C141.7490234375,155.625,134.26904296875,147.091064453125,129.85400390625,141.77001953125L128.260009765625,139.8499755859375L126.64501953125,141.751953125C121.677978515625,147.60498046875,116.6300048828125,153.47705078125,111.7769775390625,159.10205078125L111.7769775390625,129.85693359375C123.949951171875,114.824951171875,142.7239990234375,91.4534912109375,156.947021484375,73.625732421875L184.22705078125,73.625732421875C170.0880126953125,89.8582763671875,155.56201171875,106.60693359375,141.47705078125,123.9119873046875L140.373046875,125.26708984375L141.510986328125,126.595947265625C143.18505859375,128.552001953125,174.3389892578125,164.4990234375,184.259033203125,175.945068359375L159.52197265625,175.945068359375Z';

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'David Flanagan',
  alternateName: 'rawkode',
  jobTitle: 'Senior Solutions Engineer',
  worksFor: { '@type': 'Organization', name: 'CoreWeave' },
  founder: { '@type': 'Organization', name: 'Rawkode Academy', url: 'https://rawkode.academy' },
  address: { '@type': 'PostalAddress', addressLocality: 'Glasgow', addressCountry: 'GB' },
  description: bios[0].paragraphs.join(' '),
  url: 'https://rawkode.dev/biography',
  sameAs: socials.map((s) => s.href),
};
---

<Layout
  title="Biography & Speaker Kit | David Flanagan"
  description="Speaker kit for David Flanagan (rawkode): bios, headshot, and the details conference organisers need for their schedule."
  type="profile"
  jsonLd={personJsonLd}
>
  <Nav />
  <main id="main-content">
    <section class="bio-hero">
      <div class="container bio-hero__inner">
        <div class="bio-hero__copy">
          <h1>David Flanagan</h1>
          <p class="bio-hero__handle">rawkode</p>
          <p class="bio-hero__location">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            Glasgow, Scotland
          </p>
          <p class="bio-hero__tagline">{tagline}</p>
        </div>

        <figure class="portrait-card">
          <img
            src={rawkodePhoto.src}
            width={rawkodePhoto.width}
            height={rawkodePhoto.height}
            alt="David Flanagan"
            class="portrait-card__photo"
            loading="eager"
            decoding="async"
          />
          <a href={rawkodePhoto.src} download="david-flanagan-headshot.jpg" class="portrait-card__download" aria-label="Download high-resolution headshot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14"/>
            </svg>
            <span>Download HD</span>
          </a>
          <figcaption>
            <span>Speaker, Educator, Continuous Learner.</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="bio-section">
      <div class="container bio-grid">
        <div class="bio-panel">
          <header class="panel-head">
            <h2>Quick facts</h2>
          </header>
          <dl class="facts">
            {facts.map((fact) => (
              <div class="facts__row">
                <dt>{fact.label}</dt>
                <dd>
                  {fact.status && <span class="status-dot" aria-hidden="true"></span>}
                  <span id={`fact-${fact.label.toLowerCase().replaceAll(' ', '-')}`}>{fact.value}</span>
                  <button class="copy-btn copy-btn--icon" type="button" data-copy-target={`fact-${fact.label.toLowerCase().replaceAll(' ', '-')}`} aria-label={`Copy ${fact.label}`}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/>
                    </svg>
                  </button>
                </dd>
              </div>
            ))}
          </dl>
        </div>

        <div class="bio-panel bio-panel--bios">
          <header class="panel-head">
            <h2>Biography</h2>
          </header>
          <div class="bio-cards">
            {bios.map((bio) => (
              <article class="bio-card">
                <header>
                  <h2>{bio.label}</h2>
                  <span>{bio.note}</span>
                  <button class="copy-btn" type="button" data-copy-target={`bio-${bio.id}`}>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/>
                    </svg>
                    <span class="copy-btn__label">Copy</span>
                  </button>
                </header>
                <div class="bio-card__text" id={`bio-${bio.id}`}>
                  {bio.paragraphs.map((para) => <p>{para}</p>)}
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="bio-section">
      <div class="container bio-bottom">
        <div class="bio-panel">
          <header class="panel-head">
            <h2>Topics</h2>
          </header>
          <ul class="topics" role="list">
            {topics.map((topic) => <li>{topic}</li>)}
          </ul>
        </div>

        <div class="bio-panel">
          <header class="panel-head">
            <h2>Connect</h2>
          </header>
          <ul class="socials" role="list">
            {socials.map((social) => (
              <li>
                <a href={social.href} target={social.href.startsWith('mailto:') ? undefined : '_blank'} rel={social.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}>
                  <span class="socials__label">
                    {social.icon === 'academy' ? (
                      <svg class="socials__icon socials__icon--academy" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
                        <rect x="71" y="62" width="114" height="134" class="socials__academy-backplate"></rect>
                        <path d={academyIconPath}></path>
                      </svg>
                    ) : (
                      <svg class="socials__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        {socialIconPaths[social.icon].map((path) => <path d={path} />)}
                      </svg>
                    )}
                    <span>{social.label}</span>
                  </span>
                  <strong>{social.handle}</strong>
                  <svg class="socials__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17 17 7M9 7h8v8"/>
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <a href={rawkodePhoto.src} download="david-flanagan.jpg" class="download-card">
          <span>Download headshot</span>
          <strong>High-resolution speaker photo</strong>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14"/>
          </svg>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const supportsCopy = !!(navigator.clipboard && navigator.clipboard.writeText);

  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    if (!supportsCopy) {
      btn.hidden = true;
      return;
    }

    const targetId = btn.dataset.copyTarget;
    const labelEl = btn.querySelector<HTMLElement>('.copy-btn__label');
    const defaultLabel = labelEl?.textContent ?? 'Copy';
    let resetTimer: number | undefined;

    btn.addEventListener('click', async () => {
      const target = targetId ? document.getElementById(targetId) : null;
      if (!target) return;
      const paragraphs = target.querySelectorAll('p');
      const text = paragraphs.length
        ? [...paragraphs].map((p) => p.textContent?.trim() ?? '').filter(Boolean).join('\n\n')
        : (target.textContent ?? '').trim();
      if (!text) return;

      try {
        await navigator.clipboard.writeText(text);
        btn.classList.add('is-copied');
        if (labelEl) labelEl.textContent = 'Copied';
        window.clearTimeout(resetTimer);
        resetTimer = window.setTimeout(() => {
          btn.classList.remove('is-copied');
          if (labelEl) labelEl.textContent = defaultLabel;
        }, 1800);
      } catch {
        /* clipboard write blocked; visible text remains selectable */
      }
    });
  });
</script>

<style>
  .bio-hero {
    padding-block: var(--space-10) var(--space-6);
  }

  .bio-hero__inner {
    display: grid;
    gap: var(--space-8);
  }

  .bio-hero__copy {
    display: grid;
    gap: var(--space-3);
    align-content: center;
  }

  .bio-hero h1 {
    margin: 0;
    font-size: clamp(2.35rem, 10vw, 4.5rem);
  }

  .bio-hero__handle {
    margin: calc(-1 * var(--space-2)) 0 0;
    color: var(--color-accent);
    font-size: clamp(1.35rem, 6vw, 2rem);
    font-weight: 650;
    line-height: 1.1;
  }

  .bio-hero__location {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin: var(--space-2) 0 0;
    color: var(--text-secondary);
    font-size: 0.92rem;
  }

  .bio-hero__location svg {
    width: 16px;
    height: 16px;
    color: var(--color-accent-cyan);
  }

  .bio-hero__tagline {
    max-width: 42rem;
    margin: var(--space-2) 0 0;
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .portrait-card {
    position: relative;
    overflow: hidden;
    width: min(100%, 360px);
    margin: 0;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    background: var(--surface-raised);
    box-shadow: none;
  }

  .portrait-card__photo {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3.35;
    object-fit: cover;
    object-position: top center;
    filter: saturate(0.84) contrast(1.05) brightness(0.86);
  }

  .portrait-card__download {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 34px;
    padding: 0.42rem 0.62rem;
    border: 1px solid color-mix(in oklch, var(--border-default) 76%, white);
    border-radius: var(--radius-md);
    background: color-mix(in oklch, var(--surface-raised) 82%, transparent);
    color: var(--text-primary);
    font-size: 0.78rem;
    font-weight: 650;
    line-height: 1;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    opacity: 1;
    z-index: 1;
    backdrop-filter: blur(14px) saturate(1.2);
    transition:
      opacity var(--dur-fast) var(--ease-out-expo),
      transform var(--dur-fast) var(--ease-out-expo),
      border-color var(--dur-fast) var(--ease-out-expo),
      background var(--dur-fast) var(--ease-out-expo);
  }

  .portrait-card__download:hover,
  .portrait-card__download:focus-visible {
    border-color: var(--border-strong);
    background: var(--surface-raised);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .portrait-card__download svg {
    width: 15px;
    height: 15px;
    color: var(--color-accent);
  }

  .portrait-card figcaption {
    padding: var(--space-4);
    border-top: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    font-size: 0.88rem;
  }

  .portrait-card span {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .portrait-card i,
  .status-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent-success);
  }

  @media (hover: hover) and (pointer: fine) {
    .portrait-card__download {
      opacity: 0;
      pointer-events: none;
      transform: translateY(-4px);
    }

    .portrait-card:hover .portrait-card__download,
    .portrait-card:focus-within .portrait-card__download {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }
  }

  .bio-section {
    padding-block: var(--space-5);
  }

  .bio-grid,
  .bio-bottom {
    display: grid;
    align-items: start;
    gap: var(--space-4);
  }

  .bio-panel,
  .download-card {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    background: var(--surface-glass);
    box-shadow: var(--shadow-sm);
  }

  .bio-panel {
    overflow: hidden;
  }

  .panel-head {
    padding: var(--space-4);
    border-bottom: 1px solid var(--border-subtle);
  }

  .panel-head h2 {
    margin: 0;
    color: var(--text-tertiary);
    font-family: var(--fonts-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .facts {
    display: grid;
    margin: 0;
  }

  .facts__row {
    display: grid;
    gap: var(--space-2);
    padding: var(--space-4);
    border-bottom: 1px solid var(--border-subtle);
  }

  .facts__row:last-child {
    border-bottom: 0;
  }

  .facts dt {
    color: var(--text-tertiary);
    font-family: var(--fonts-mono);
    font-size: 0.72rem;
  }

  .facts dd {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
    color: var(--text-primary);
    font-size: 0.92rem;
  }

  .facts dd span:not(.status-dot) {
    min-width: 0;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-height: 34px;
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--surface-glass);
    color: var(--text-secondary);
    font-family: var(--fonts-sans);
    font-size: 0.82rem;
    font-weight: 650;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out-expo),
      border-color var(--dur-fast) var(--ease-out-expo),
      background var(--dur-fast) var(--ease-out-expo);
  }

  .copy-btn:hover,
  .copy-btn.is-copied {
    color: var(--text-primary);
    border-color: var(--border-default);
    background: var(--surface-raised);
  }

  .copy-btn svg {
    width: 15px;
    height: 15px;
  }

  .copy-btn--icon {
    width: 32px;
    min-height: 32px;
    padding: 0;
    margin-left: auto;
  }

  .bio-cards {
    display: grid;
  }

  .bio-card {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-4);
    border-bottom: 1px solid var(--border-subtle);
  }

  .bio-card:last-child {
    border-bottom: 0;
  }

  .bio-card header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    align-items: center;
    gap: var(--space-3);
  }

  .bio-card h2 {
    margin: 0;
    font-size: 1rem;
  }

  .bio-card header > span {
    color: var(--text-tertiary);
    font-family: var(--fonts-mono);
    font-size: 0.72rem;
  }

  .bio-card__text {
    display: grid;
    gap: var(--space-3);
  }

  .bio-card__text p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0;
    padding: var(--space-4);
    list-style: none;
  }

  .topics li {
    padding: 0.38rem 0.58rem;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-size: 0.82rem;
  }

  .socials {
    display: grid;
    margin: 0;
    padding: 0;
    list-style: none;
  }

