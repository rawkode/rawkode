---
import type { CollectionEntry } from 'astro:content';

interface Props {
  app: CollectionEntry<'apps'>['data'];
}

const { app } = Astro.props;

const repoUrl = app.repoUrl ?? (app.repoPath ? `https://github.com/rawkode/rawkode/tree/main/${app.repoPath}` : null);
const href = app.websiteUrl ?? repoUrl;
const mark = app.name === 'kubectl-ditto' ? '>_' : app.name.slice(0, 1).toUpperCase();
---

<article class:list={['app-card', { 'app-card--featured': app.featured }]}>
  <div class="app-card__mark" aria-hidden="true">{mark}</div>

  <div class="app-card__main">
    <header class="app-card__head">
      <h3 class="app-card__name">{app.name}</h3>
    </header>
    <p class="app-card__tagline">{app.tagline}</p>
    <p class="app-card__description">{app.description}</p>
    <ul class="app-card__tags" role="list" aria-label="Tags">
      {app.tags.slice(0, 4).map((tag) => (
        <li>{tag}</li>
      ))}
    </ul>
  </div>

  <aside class="app-card__meta" aria-label={`${app.name} metadata`}>
    <span>{app.platform.join(' / ')}</span>
    {href && (
      <a href={href} target="_blank" rel="noopener noreferrer" class="app-card__action" aria-label={`Open ${app.name}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17 17 7M9 7h8v8"/>
        </svg>
      </a>
    )}
  </aside>
</article>

<style>
  .app-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-4);
    align-items: start;
    padding: var(--space-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--surface-2);
    box-shadow: none;
    transition:
      border-color var(--dur-fast) var(--ease-out-expo),
      background var(--dur-fast) var(--ease-out-expo),
      transform var(--dur-fast) var(--ease-out-expo);
  }

  .app-card:hover {
    border-color: var(--border-default);
    background: var(--surface-3);
    transform: translateY(-1px);
  }

  .app-card--featured {
    border-color: color-mix(in oklch, var(--color-accent) 42%, var(--border-default));
    background: color-mix(in oklch, var(--color-accent-soft) 42%, var(--surface-2));
  }

  .app-card--featured .app-card__mark {
    border-color: color-mix(in oklch, var(--color-accent) 34%, var(--border-subtle));
    background: var(--color-accent-soft);
    color: var(--color-accent-hover);
  }

  .app-card__mark {
    display: grid;
    place-items: center;
    width: 44px;
    aspect-ratio: 1;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--surface-3);
    color: var(--text-primary);
    font-family: var(--fonts-mono);
    font-size: 1rem;
    font-weight: 700;
  }

  .app-card__main {
    min-width: 0;
    display: grid;
    gap: var(--space-2);
  }

  .app-card__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .app-card__name {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .app-card__tagline,
  .app-card__description {
    margin: 0;
  }

  .app-card__tagline {
    color: var(--text-primary);
    font-size: 0.9rem;
    font-weight: 580;
    line-height: 1.45;
  }

  .app-card__description {
    display: none;
    max-width: 62ch;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .app-card__tags {
    display: none;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: var(--space-1) 0 0;
    padding: 0;
    list-style: none;
  }

  .app-card__tags li {
    padding: 0.2rem 0.45rem;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-family: var(--fonts-mono);
    font-size: 0.75rem;
  }

  .app-card__meta {
    grid-column: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    min-width: 0;
    color: var(--text-secondary);
    font-family: var(--fonts-mono);
    font-size: 0.8125rem;
  }

  .app-card__meta span {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .app-card__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    text-decoration: none;
    flex-shrink: 0;
    transition:
      transform var(--dur-fast) var(--ease-out-expo),
      border-color var(--dur-fast) var(--ease-out-expo),
      background var(--dur-fast) var(--ease-out-expo),
      color var(--dur-fast) var(--ease-out-expo);
  }

  .app-card__action:hover {
    color: var(--text-primary);
    border-color: var(--border-default);
    background: var(--surface-glass);
  }

  .app-card__action:active {
    transform: translateY(1px);
  }

  .app-card__action svg {
    width: 15px;
    height: 15px;
  }

  @media (min-width: 720px) {
    .app-card {
      grid-template-columns: auto minmax(0, 1fr) minmax(8rem, auto);
      align-items: center;
      gap: var(--space-4);
      padding: var(--space-4);
    }

    .app-card__meta {
      grid-column: auto;
      justify-content: end;
    }
  }

  @media (min-width: 1040px) {
    .app-card {
      padding: var(--space-5);
    }

    .app-card__description,
    .app-card__tags {
      display: flex;
    }
  }
</style>
