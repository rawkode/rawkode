---
import type { CollectionEntry } from 'astro:content';

interface Props {
  app: CollectionEntry<'apps'>['data'];
}

const { app } = Astro.props;

const repoUrl = app.repoUrl ?? (app.repoPath ? `https://github.com/rawkode/rawkode/tree/main/${app.repoPath}` : null);
const isRichFeatured = app.featured && Boolean(app.highlight);
---

<article class:list={['app-card', { 'app-card--featured': app.featured, 'app-card--rich': isRichFeatured }]}>
  <header class="app-card__head">
    <p class="app-card__eyebrow">
      {app.featured && (
        <>
          <span class="app-card__featured">Featured</span>
          <span class="app-card__sep" aria-hidden="true">·</span>
        </>
      )}
      <span>{app.platform.join(' / ')}</span>
    </p>
  </header>

  <div class="app-card__body">
    <h3 class="app-card__name">{app.name}</h3>
    <p class="app-card__tagline">{app.tagline}</p>
    <p class="app-card__description">{app.description}</p>
  </div>

  {isRichFeatured && (
    <aside class="app-card__highlight" aria-label="Highlight">
      <p class="app-card__highlight-text">{app.highlight}</p>
    </aside>
  )}

  <footer class="app-card__foot">
    <ul class="app-card__tags" role="list" aria-label="Tags">
      {app.tags.map((tag) => (
        <li class="app-card__tag">{tag}</li>
      ))}
    </ul>

    <div class="app-card__actions">
      {repoUrl && (
        <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="app-card__icon-link" aria-label={`View ${app.name} on GitHub`}>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
      )}
      {app.websiteUrl && (
        <a href={app.websiteUrl} target="_blank" rel="noopener noreferrer" class="app-card__icon-link" aria-label={`Visit ${app.name} website`}>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9"/>
            <path d="M3 12h18"/>
            <path d="M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18z"/>
          </svg>
        </a>
      )}
    </div>
  </footer>
</article>

<style>
  .app-card {
    position: relative;
    background: var(--surface-2);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    height: 100%;
    transition:
      border-color 0.3s var(--ease-out-expo),
      transform 0.4s var(--ease-out-expo),
      box-shadow 0.4s var(--ease-out-expo);
  }

  @media (hover: hover) {
    .app-card:hover {
      border-color: var(--border-default);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
  }

  /* ─── Header eyebrow ────────────────────────────────────────────────────── */
  .app-card__head { min-height: 1.25rem; }

  .app-card__eyebrow {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    margin: 0;
    font-family: var(--fonts-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    line-height: 1;
  }

  .app-card__featured { color: var(--color-accent); }
  .app-card__sep {
    margin-inline: 0.55em;
    opacity: 0.5;
    font-weight: 400;
  }

  /* ─── Body ──────────────────────────────────────────────────────────────── */
  .app-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .app-card__name {
    font-family: var(--fonts-serif);
    font-size: clamp(1.5rem, 1.1vw + 1rem, 1.85rem);
    font-style: normal;
    font-weight: 600;
    letter-spacing: -0.022em;
    line-height: 1.05;
    color: var(--text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .app-card__tagline {
    font-family: var(--fonts-serif);
    font-size: 1.0625rem;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: -0.005em;
    color: var(--text-primary);
    margin: 0;
    max-width: 38ch;
    text-wrap: balance;
  }

  .app-card__description {
    font-family: var(--fonts-sans);
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }

  /* ─── Highlight callout (rich featured only) ───────────────────────────── */
  .app-card__highlight {
    display: none;
  }

  .app-card__highlight-text {
    font-family: var(--fonts-serif);
    font-style: italic;
    font-size: clamp(1.25rem, 1.4vw + 0.5rem, 1.65rem);
    line-height: 1.35;
    letter-spacing: -0.012em;
    color: var(--text-primary);
    text-wrap: balance;
    margin: 0;
  }

  /* ─── Footer ────────────────────────────────────────────────────────────── */
  .app-card__foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-subtle);
    margin-top: auto;
  }

  .app-card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    flex: 1;
    min-width: 0;
    margin: 0;
    padding: 0;
    font-family: var(--fonts-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    line-height: 1.8;
  }

  .app-card__tag { white-space: nowrap; }
  .app-card__tag:not(:last-child)::after {
    content: '·';
    display: inline-block;
    padding: 0 0.55em;
    color: var(--text-tertiary);
    opacity: 0.55;
    font-weight: 400;
  }

  .app-card__actions {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
    margin-bottom: -4px;
  }

  .app-card__icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    color: var(--text-tertiary);
    text-decoration: none;
    transition:
      color 0.25s var(--ease-out-expo),
      background 0.25s var(--ease-out-expo),
      transform 0.25s var(--ease-out-expo);
  }

  .app-card__icon-link:hover {
    color: var(--text-primary);
    background: var(--surface-3);
    transform: translateY(-1px);
  }

  /* ─── Featured (base, no highlight) — bigger type only ─────────────────── */
  .app-card--featured {
    background: var(--surface-3);
    border-color: color-mix(in oklch, var(--color-accent) 22%, var(--border-default));
    box-shadow: inset 4px 0 0 0 var(--color-accent);
  }

  .app-card--featured .app-card__name {
    font-size: clamp(2rem, 2vw + 1.2rem, 2.85rem);
  }

  .app-card--featured .app-card__tagline {
    font-size: 1.2rem;
    max-width: 54ch;
  }

  .app-card--featured .app-card__description {
    font-size: 0.975rem;
    max-width: 64ch;
  }

  @media (hover: hover) {
    .app-card--featured:hover {
      border-color: color-mix(in oklch, var(--color-accent) 40%, var(--border-default));
      box-shadow:
        inset 4px 0 0 0 var(--color-accent),
        var(--shadow-md);
    }
  }

  /* ─── Rich featured — 2-column with highlight callout on the right ─────── */
  .app-card--rich { padding: var(--space-10); }
  .app-card--rich .app-card__highlight { display: block; }

  @media (min-width: 760px) {
    .app-card--rich {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
      grid-template-rows: auto auto auto;
      column-gap: var(--space-12);
      row-gap: var(--space-6);
    }
    .app-card--rich .app-card__head     { grid-column: 1; grid-row: 1; }
    .app-card--rich .app-card__body     { grid-column: 1; grid-row: 2; }
    .app-card--rich .app-card__highlight {
      grid-column: 2;
      grid-row: 1 / span 2;
      display: flex;
      align-items: center;
      padding-left: var(--space-8);
      border-left: 1px solid color-mix(in oklch, var(--color-accent) 40%, var(--border-default));
    }
    .app-card--rich .app-card__foot     { grid-column: 1 / -1; grid-row: 3; }
  }

  /* ─── Reduced motion ────────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .app-card,
    .app-card__icon-link { transition: none; }
  }
</style>
