{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "rawkode-dev",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "routes": [
    {
      "custom_domain": true,
      "pattern": "rawkode.dev",
    },
  ],
  "observability": { "enabled": true },

  "vars": {
    "PDS_DID": "did:web:rawkode.dev",
    "PDS_HANDLE": "rawkode.dev",
    "PDS_HOSTNAME": "rawkode.dev",
    "PDS_CORS_ORIGIN": "https://rawkode.dev,https://bsky.app",
    "PDS_EMAIL": "david@rawkode.dev",
    "PDS_CONTACT_EMAIL": "david@rawkode.dev",
  },

  "d1_databases": [
    {
      "binding": "ALTERAN_DB",
      "database_name": "rawkode-dev-pds",
      "database_id": "83e8786b-4710-45cb-9e5f-52c8976bef9d",
      "migrations_dir": "./node_modules/@alteran-social/astro/migrations",
    },
  ],

  "r2_buckets": [
    {
      "binding": "ALTERAN_BLOBS",
      "bucket_name": "rawkode-dev-pds",
    },
  ],

  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "3b803cb67d6a495985facb2fb4339790",
    },
  ],

  "durable_objects": {
    "bindings": [
      { "name": "ALTERAN_SEQUENCER", "class_name": "Sequencer" },
    ],
  },

  "migrations": [
    { "tag": "v1", "new_classes": ["Sequencer"] },
  ],
}
