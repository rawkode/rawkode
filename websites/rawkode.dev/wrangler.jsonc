{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "rawkode-dev",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
  },
  "build": {
    "command": "bun run build",
    "cwd": ".",
  },
  "routes": [
    {
      "custom_domain": true,
      "pattern": "rawkode.dev",
    },
  ],
  "observability": { "enabled": true },
}
